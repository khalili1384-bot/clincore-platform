{"case_id": "3b251fd9-ae2c-4c1d-845f-b7f5d1051ab6", "tenant_id": "5c091694-0e5a-46a0-b1d5-01fb7655f0ab", "api_key": "unknown", "narrative": "\u0645\u0631\u062f 70 \u0633\u0627\u0644\u0647\n\u062a\u0627\u0631\u06cc\u062e: \u06f7 \u0627\u0633\u0641\u0646\u062f \u06f1\u06f4\u06f0\u06f4 \n1. \u0634\u06a9\u0627\u06cc\u062a \u0627\u0635\u0644\u06cc \u0645\u0634\u06a9\u0644 \u0627\u0635\u0644\u06cc \u0634\u0645\u0627 \u0686\u06cc\u0633\u062a\u061f \n\u062c: \u0622\u0633\u0645\u00a0 \u0648 \u067e\u0631\u0648\u0633\u062a\u0627\u062a.\n\u0622\u0633\u0645 \u060c \u0628\u06cc\u0634\u062a\u0631 \u0627\u0632 \u06f2\u06f0 \u0633\u0627\u0644 \u0648 \u067e\u0631\u0648\u0633\u062a\u0627\u062a \u0627\u0632 \u06f2 \u0633\u0627\u0644 \u0628\u0647 \u0627\u06cc\u0646 \u0633\u0648 .\n(\u0628\u0627 \u062c\u0645\u0644\u0627\u062a \u062e\u0648\u062f\u062a\u0627\u0646 \u062a\u0648\u0636\u06cc\u062d \u062f\u0647\u06cc\u062f)\n\u0627\u06cc\u0646 \u0645\u0634\u06a9\u0644 \u0627\u0632 \u0686\u0647 \u0632\u0645\u0627\u0646\u06cc \u0634\u0631\u0648\u0639 \u0634\u062f\u061f\n\n2. \u0622\u063a\u0627\u0632 \u0645\u0634\u06a9\u0644 \u0622\u06cc\u0627 \u0642\u0628\u0644 \u0627\u0632 \u0634\u0631\u0648\u0639 \u0627\u06cc\u0646 \u0645\u0634\u06a9\u0644\u060c \u0627\u062a\u0641\u0627\u0642 \u06cc\u0627 \u0631\u0648\u06cc\u062f\u0627\u062f \u062e\u0627\u0635\u06cc \u062f\u0631 \u0632\u0646\u062f\u06af\u06cc\u200c\u062a\u0627\u0646 \u0627\u0641\u062a\u0627\u062f\u0647 \u0628\u0648\u062f\u061f \n(\u0645\u062b\u0644 \u0641\u0648\u062a\u060c \u062c\u062f\u0627\u06cc\u06cc\u060c \u0628\u06cc\u0645\u0627\u0631\u06cc\u060c \u062a\u0635\u0627\u062f\u0641\u060c \u0627\u0633\u062a\u0631\u0633 \u0634\u062f\u06cc\u062f\u060c \u0627\u0632 \u062f\u0633\u062a \u062f\u0627\u062f\u0646 \u0634\u063a\u0644)\u0627\u06af\u0631 \u0628\u0644\u0647\u060c \u0627\u06cc\u0646 \u0627\u062a\u0641\u0627\u0642 \u0686\u0637\u0648\u0631 \u0631\u0648\u06cc \u0634\u0645\u0627 \u062a\u0623\u062b\u06cc\u0631 \u06af\u0630\u0627\u0634\u062a\u061f\n\u062c: \u0646\u0647 \u062e\u06cc\u0631 \n3. \u0627\u062d\u0633\u0627\u0633\u0627\u062a \u062f\u0631 \u0637\u0648\u0644 \u0631\u0648\u0632 \u0628\u06cc\u0634\u062a\u0631 \u0686\u0647 \u0627\u062d\u0633\u0627\u0633\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f\n\u0622\u06cc\u0627 \u0646\u06af\u0631\u0627\u0646\u06cc \u06cc\u0627 \u0627\u0636\u0637\u0631\u0627\u0628 \u062e\u0627\u0635\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f \u0627\u06af\u0631 \u0628\u0644\u0647\u060c \u062f\u0631\u0628\u0627\u0631\u0647 \u0686\u0647 \u0686\u06cc\u0632\u06cc\u061f\u0622\u06cc\u0627 \u062a\u0631\u0633 \u062e\u0627\u0635\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f \u0627\u06af\u0631 \u0628\u0644\u0647\u060c \u0627\u0632 \u0686\u0647 \u0686\u06cc\u0632\u06cc\u061f\n\u062c: \u0628\u0639\u0636\u06cc \u0645\u0648\u0627\u0642\u0639 \u0627\u0632 \u0634\u062e\u0635 \u0648 \u06cc\u0627 \u0627\u0634\u062e\u0627\u0635\u06cc \u06a9\u0647 \u0628\u0627 \u0645\u0646 \u062f\u0634\u0645\u0646\u06cc \u062f\u0627\u0631\u062f \u060c \u062a\u0631\u0633 \u062e\u0641\u06cc\u0641 \u062f\u0627\u0631\u0645 \u06a9\u0647 \u06af\u0648\u06cc\u0627 \u0628\u0647 \u0645\u0646 \u0636\u0631\u0631 \u0645\u06cc \u0631\u0633\u0627\u0646\u0646\u062f \u0648 \u0628\u0639\u062f \u0647\u0627 \u0645\u062a\u0648\u062c\u0647 \u0645\u06cc \u0634\u0648\u0645 \u06a9\u0647 \u062a\u0631\u0633\u0645 \u0648\u0627\u0647\u06cc \u0648\u00a0 \u0628\u06cc \u0627\u0633\u0627\u0633 \u0628\u0648\u062f\u0647 \u0627\u0633\u062a.\n\n4. \u0648\u0627\u06a9\u0646\u0634\u200c\u0647\u0627\u0648\u0642\u062a\u06cc \u0646\u0627\u0631\u0627\u062d\u062a \u06cc\u0627 \u0639\u0635\u0628\u0627\u0646\u06cc \u0645\u06cc\u200c\u0634\u0648\u06cc\u062f\u060c \u0686\u0647 \u06a9\u0627\u0631\u06cc \u0627\u0646\u062c\u0627\u0645 \u0645\u06cc\u200c\u062f\u0647\u06cc\u062f\u061f\u0622\u06cc\u0627 \u06af\u0631\u06cc\u0647 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u062f\u061f \u0627\u06af\u0631 \u0628\u0644\u0647\u060c \u0628\u0639\u062f \u0627\u0632 \u06af\u0631\u06cc\u0647 \u062d\u0627\u0644\u062a\u0627\u0646 \u0686\u0637\u0648\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f\u0648\u0642\u062a\u06cc \u06a9\u0633\u06cc \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u062f \u062f\u0644\u062f\u0627\u0631\u06cc\u200c\u062a\u0627\u0646 \u0628\u062f\u0647\u062f \u06cc\u0627 \u06a9\u0645\u06a9\u062a\u0627\u0646 \u06a9\u0646\u062f\u060c \u0686\u0647 \u062d\u0633\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f\n\u062c:\u00a0 \u062f\u0631 \u0648\u0642\u062a \u0639\u0635\u0628\u0627\u0646\u06cc\u062a \u0648 \u0646\u0627\u0631\u0627\u062d\u062a\u06cc \u060c \u063a\u0645\u06af\u06cc\u0646 \u0645\u06cc \u0634\u0648\u0645 \u0648\u0644\u06cc \u06af\u0631\u0628\u0647 \u0646\u0645\u06cc \u06a9\u0646\u0645 .\n5. \u0631\u0648\u0627\u0628\u0637 \u062a\u0631\u062c\u06cc\u062d \u0645\u06cc\u200c\u062f\u0647\u06cc\u062f \u062a\u0646\u0647\u0627 \u0628\u0627\u0634\u06cc\u062f \u06cc\u0627 \u0628\u0627 \u062f\u06cc\u06af\u0631\u0627\u0646\u061f \u0686\u0631\u0627\u061f\u062f\u0631 \u062c\u0645\u0639\u200c\u0647\u0627\u06cc \u0627\u062c\u062a\u0645\u0627\u0639\u06cc (\u0645\u0647\u0645\u0627\u0646\u06cc\u060c \u062f\u0648\u0631\u0647\u0645\u06cc) \u0686\u0647 \u062d\u0633\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f\n\u062c: \u062a\u0631\u062c\u06cc\u062d \u0645\u06cc \u062f\u0647\u0645 \u062f\u0631 \u062c\u0645\u0639 \u0628\u0627\u0634\u0645 \u060c \u062f\u0631 \u062c\u0645\u0639 \u062f\u0648\u0633\u062a\u0627\u0646 \u0648 \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u062d\u0633 \u062e\u06cc\u0644\u06cc \u062e\u0648\u0628\u06cc \u062f\u0627\u0631\u0645 .\n\n6. \u062e\u0648\u0627\u0628 \u062a\u0627\u0646 \u0686\u0637\u0648\u0631 \u0627\u0633\u062a\u061f\n\u0622\u06cc\u0627 \u0645\u0634\u06a9\u0644\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f\n\u06af\u0631 \u0645\u0634\u06a9\u0644 \u062f\u0627\u0631\u06cc\u062f\u060c \u0686\u0647 \u0632\u0645\u0627\u0646\u06cc \u0628\u06cc\u0634\u062a\u0631 \u0627\u0633\u062a\u061f (\u0645\u0648\u0642\u0639 \u062e\u0648\u0627\u0628\u06cc\u062f\u0646\u060c \u0648\u0633\u0637 \u0634\u0628\u060c \u0635\u0628\u062d \u0632\u0648\u062f\u060c \u0646\u06cc\u0645\u0647\u200c\u0634\u0628)\n\u0622\u06cc\u0627 \u062e\u0648\u0627\u0628 \u06cc\u0627 \u06a9\u0627\u0628\u0648\u0633 \u062e\u0627\u0635\u06cc \u0645\u06cc\u200c\u0628\u06cc\u0646\u06cc\u062f\u061f\n\u062c: \u062e\u0648\u0627\u0628\u0645 \u0645\u0646\u0638\u0645 \u0627\u0633\u062a \u0648 \u06af\u0627\u0647\u06cc \u0628\u0639\u062f \u0627\u0632 \u06f4 \u06cc\u0627 \u06f5\u00a0 \u0633\u0627\u0639\u062a \u062e\u0648\u0627\u0628\u06cc\u062f\u0646 \u0628\u0631\u0627\u06cc \u062f\u0641\u0639 \u0627\u062f\u0631\u0627\u0631 \u0628\u06cc\u062f\u0627\u0631 \u0645\u06cc \u0634\u0648\u0645 .\n\u0628\u0639\u0636\u06cc \u0645\u0648\u0627\u0642\u0639 \u06a9\u0627\u0628\u0648\u0633\u06cc \u0645\u06cc \u0628\u06cc\u0646\u0645 \u06a9\u0647 \u0634\u062e\u0635 \u06cc\u0627 \u0627\u0634\u062e\u0627\u0635 \u0622\u0634\u0646\u0627 \u0648 \u06cc\u0627 \u06af\u0627\u0647\u06cc \u0686\u0647\u0631\u0647 \u0647\u0627\u06cc \u0646\u0627 \u0622\u0634\u0646\u0627 \u0645\u0631\u0627 \u0627\u0630\u06cc\u062a \u0645\u06cc \u06a9\u0646\u0646\u062f \u0648 \u0645\u06cc \u062e\u0648\u0627\u0647\u0646\u062f \u0628\u0647 \u0645\u0646 \u0622\u0632\u0627\u0631 \u0628\u0631\u0633\u0627\u0646\u0646\u062f \u0648 \u0627\u06a9\u062b\u0631 \u0645\u0648\u0627\u0642\u0639 \u0642\u062f\u0631\u062a \u062f\u0641\u0627\u0639 \u0646\u062f\u0627\u0631\u0645 \u060c \u0686\u0648\u0646 \u0628\u06cc\u062f\u0627\u0631 \u0645\u06cc \u0634\u0648\u0645 \u060c \u0628\u0633\u06cc\u0627\u0631 \u062e\u0648\u0634\u062d\u0627\u0644 \u0645\u06cc \u0634\u0648\u0645 \u06a9\u0647 \u0622\u0646 \u0627\u062a\u0641\u0627\u0642\u0627\u062a \u0628\u062f \u062f\u0631 \u0631\u0648\u06cc\u0627 \u0627\u062a\u0641\u0627\u0642 \u0627\u0641\u062a\u0627\u062f\u0647 \u0627\u0633\u062a.\n\n7. \u062a\u0635\u0645\u06cc\u0645\u200c\u06af\u06cc\u0631\u06cc \u0648\u0642\u062a\u06cc \u0628\u0627\u06cc\u062f \u062a\u0635\u0645\u06cc\u0645 \u0628\u06af\u06cc\u0631\u06cc\u062f\u060c \u0686\u0637\u0648\u0631 \u0639\u0645\u0644 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u062f\u061f\n\u062c: \u062a\u0644\u0627\u0634 \u0645\u06cc \u06a9\u0646\u0645 \u06a9\u0647 \u0641\u0648\u0631\u0627\u064b \u0627\u0642\u062f\u0627\u0645 \u06a9\u0646\u0645 \u0648 \u062a\u0627\u062e\u06cc\u0631 \u062f\u0631 \u0639\u0645\u0644 \u0631\u0627 \u062e\u0648\u0634 \u0646\u062f\u0627\u0631\u0645 \u0648 \u0627\u06af\u0631 \u0642\u062f\u0631\u062a \u0628\u0631 \u0627\u062c\u0631\u0627\u06cc \u06a9\u0627\u0631\u06cc \u0631\u0627 \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u0645 \u060c \u0639\u0627\u062c\u0644 \u0627\u0646\u062c\u0627\u0645 \u0645\u06cc \u062f\u0647\u0645 .\n\n8. \u0646\u0638\u0645 \u0648 \u062a\u0631\u062a\u06cc\u0628 \u0628\u0631\u0627\u06cc \u0634\u0645\u0627 \u0646\u0638\u0645 \u0648 \u062a\u0631\u062a\u06cc\u0628 \u0686\u0642\u062f\u0631 \u0645\u0647\u0645 \u0627\u0633\u062a\u061f\n\u062c: \u0628\u0633\u06cc\u0627\u0631 \u0645\u0647\u0645 \u0627\u0633\u062a \u0648 \u0628\u0633\u06cc\u0627\u0631 \u0645\u0646\u0638\u0645 \u0648 \u0622\u0646 \u062a\u0627\u06cc\u0645 \u0647\u0633\u062a\u0645 \u0648 \u0627\u0632 \u062a\u0631\u062f\u06cc\u062f \u0648 \u062a\u0627\u062e\u06cc\u0631 \u06a9\u0627\u0631\u0647\u0627 \u0628\u06cc\u0632\u0627\u0631\u0645 .\n\n9. \u0628\u062f\u062a\u0631 \u0634\u062f\u0646\u0634\u06a9\u0627\u06cc\u062a \u0634\u0645\u0627 \u062f\u0631 \u0686\u0647 \u0632\u0645\u0627\u0646\u06cc \u0628\u062f\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f (\u0635\u0628\u062d\u060c \u0638\u0647\u0631\u060c \u0639\u0635\u0631\u060c \u0634\u0628\u060c \u0646\u06cc\u0645\u0647\u200c\u0634\u0628)\u062f\u0631 \u0686\u0647 \u0647\u0648\u0627\u06cc\u06cc \u0628\u062f\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f (\u0633\u0631\u062f\u060c \u06af\u0631\u0645\u060c \u0645\u0631\u0637\u0648\u0628\u060c \u0628\u0627\u062f\u06cc)\u062f\u0631 \u0686\u0647 \u0645\u0648\u0642\u0639\u06cc\u062a\u06cc \u0628\u062f\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f (\u0627\u0633\u062a\u0631\u0627\u062d\u062a\u060c \u062d\u0631\u06a9\u062a\u060c \u062a\u0646\u0647\u0627 \u0628\u0648\u062f\u0646\u060c \u062f\u0631 \u062c\u0645\u0639 \u0628\u0648\u062f\u0646)\n\u062c:\u00a0 \u062f\u0631 \u0646\u06cc\u0645\u0647 \u0647\u0627\u06cc \u0634\u0628 \u0648 \u0647\u0646\u06af\u0627\u0645 \u0633\u062d\u0631 \u06af\u0627\u0647\u06cc \u062a\u0646\u06af\u06cc \u0646\u0641\u0633\u0645 \u0628\u062f\u062a\u0631 \u0645\u06cc \u0634\u0648\u062f.\n\u062f\u0631 \u0647\u0648\u0627\u06cc \u0633\u0631\u062f \u0648 \u0627\u0628\u0631\u06cc \u062d\u0627\u0644\u0645 \u0628\u0639\u0636\u06cc \u0645\u0648\u0627\u0642\u0639 \u0628\u062f\u00a0 \u0645\u06cc \u0634\u0648\u062f .\n\u062f\u0631 \u062d\u0631\u06a9\u062a \u06a9\u0631\u062f\u0646 \u062d\u0627\u0644\u0645 \u0628\u062f\u062a\u0631 \u0645\u06cc \u0634\u0648\u062f \u0648 \u062f\u0631 \u062a\u0646\u0647\u0627\u06cc\u06cc \u0647\u0645 \u0628\u062f \u062a\u0631 \u0645\u06cc \u0634\u0648\u062f. \n10. \u0628\u0647\u062a\u0631 \u0634\u062f\u0646\u0634\u06a9\u0627\u06cc\u062a \u0634\u0645\u0627 \u062f\u0631 \u0686\u0647 \u0645\u0648\u0627\u0642\u0639\u06cc \u0628\u0647\u062a\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f\u061f\n\u062c: \u062f\u0631 \u0647\u0648\u0627\u06cc \u067e\u0627\u06a9 \u060c \u062f\u0631 \u062c\u0645\u0639 \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u0648 \u062f\u0648\u0633\u062a\u0627\u0646 \u060c \u062f\u0631 \u0647\u0646\u06af\u0627\u0645 \u0634\u0627\u062f\u06cc \u0648 \u062e\u0648\u0634\u06cc \u060c \u062f\u0631 \u0641\u0635\u0644 \u0628\u0647\u0627\u0631 \u0648 \u0647\u0648\u0627\u06cc \u0646\u0633\u0628\u062a\u0627\u064b \u06af\u0631\u0645.\n11. \u0648\u0636\u0639\u06cc\u062a \u062c\u0633\u0645\u06cc \u0627\u0646\u0631\u0698\u06cc \u0634\u0645\u0627 \u0686\u0637\u0648\u0631 \u0627\u0633\u062a\u061f\u0627\u0634\u062a\u0647\u0627\u06cc \u0634\u0645\u0627 \u0686\u0637\u0648\u0631 \u0627\u0633\u062a\u061f\u0622\u06cc\u0627 \u0628\u0647 \u063a\u0630\u0627\u06cc \u062e\u0627\u0635\u06cc \u0645\u06cc\u0644 \u06cc\u0627 \u0628\u06cc\u0632\u0627\u0631\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f (\u0634\u0648\u0631\u060c \u0634\u06cc\u0631\u06cc\u0646\u060c \u062a\u0631\u0634\u060c \u062a\u0644\u062e\u060c \u0686\u0631\u0628\u060c \u06af\u0631\u0645\u060c \u0633\u0631\u062f)\u0645\u0639\u0645\u0648\u0644\u0627\u064b \u0633\u0631\u062f\u062a\u0627\u0646 \u0627\u0633\u062a \u06cc\u0627 \u06af\u0631\u0645\u062a\u0627\u0646\u061f\n\u062c:\u00a0 \u0648\u0636\u0639\u06cc\u062a \u062c\u0633\u0645\u06cc \u0645\u0646 \u062e\u0648\u0628 \u0627\u0633\u062a\u060c \u063a\u06cc\u0631 \u0627\u0632 \u0627\u06cc\u0627\u0645 \u0645\u0631\u06cc\u0636\u06cc \u062f\u0631 \u062d\u0627\u0644 \u0639\u0627\u062f\u06cc \u060c \u0627\u0634\u062a\u0647\u0627\u06cc\u0645 \u0646\u0648\u0631\u0645\u0627\u0644 \u0627\u0633\u062a.\n\u063a\u0630\u0627\u06cc \u0686\u0631\u0628\u060c \u0634\u06cc\u0631\u06cc\u0646 \u060c \u062a\u0644\u062e \u060c \u06af\u0631\u0645 \u0648 \u06af\u0627\u0647\u06cc \u0634\u0648\u0631 \u0631\u0627 \u062f\u0648\u0633\u062a \u062f\u0627\u0631\u0645.\n\u0645\u0639\u0645\u0648\u0644\u0627\u064b \u0627\u062d\u0633\u0627\u0633 \u0633\u0631\u0645\u0627 \u0645\u06cc \u06a9\u0646\u0645 \u060c \u062d\u062a\u06cc \u062f\u0631 \u0647\u0648\u0627\u06cc \u0645\u0639\u062a\u062f\u0644.\n\u067e\u0627\u0647\u0627\u06cc\u0645 \u06a9\u0647 \u062f\u0631 \u062a\u0627\u0628\u0633\u062a\u0627\u0646 \u0628\u0647 \u0646\u062f\u0631\u062a \u06af\u0631\u0645 \u0645\u06cc \u0622\u06cc\u062f \u0648 \u062f\u0631 \u0641\u0635\u0644 \u0632\u0645\u0633\u062a\u0627\u0646 \u0648 \u062e\u0632\u0627\u0646 \u0648 \u062d\u062a\u06cc \u0628\u0647\u0627\u0631 \u060c \u0628\u0631\u0627\u06cc \u06af\u0631\u0645 \u0634\u062f\u0646 \u067e\u0627\u0647\u0627\u06cc\u0645 \u0627\u0632 \u0645\u0634\u06a9\u00a0 \u0622\u0628 \u06af\u0631\u0645\u00a0 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc \u06a9\u0646\u0645.\n\n12. \u0633\u0627\u0628\u0642\u0647 \u062f\u0631\u0645\u0627\u0646\u0622\u06cc\u0627 \u0642\u0628\u0644\u0627\u064b \u0628\u0631\u0627\u06cc \u0627\u06cc\u0646 \u0645\u0634\u06a9\u0644 \u062f\u0631\u0645\u0627\u0646 \u062f\u0631\u06cc\u0627\u0641\u062a \u06a9\u0631\u062f\u0647\u200c\u0627\u06cc\u062f\u061f \u0686\u0647 \u062f\u0631\u0645\u0627\u0646\u06cc\u061f\u0622\u06cc\u0627 \u062f\u0627\u0631\u0648\u06cc\u06cc \u0645\u0635\u0631\u0641 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u062f\u061f (\u0647\u0631 \u062f\u0627\u0631\u0648\u06cc\u06cc \u062d\u062a\u06cc \u0642\u0631\u0635 \u0633\u0631\u062f\u0631\u062f \u06cc\u0627 \u0648\u06cc\u062a\u0627\u0645\u06cc\u0646)\u0622\u06cc\u0627 \u0633\u0627\u0628\u0642\u0647 \u0645\u0635\u0631\u0641 \u0637\u0648\u0644\u0627\u0646\u06cc\u200c\u0645\u062f\u062a \u0622\u0646\u062a\u06cc\u200c\u0628\u06cc\u0648\u062a\u06cc\u06a9\u060c \u06a9\u0648\u0631\u062a\u0648\u0646\u060c \u0642\u0631\u0635\u200c\u0647\u0627\u06cc \u0636\u062f\u0628\u0627\u0631\u062f\u0627\u0631\u06cc\u060c \u06cc\u0627 \u062f\u0627\u0631\u0648\u0647\u0627\u06cc \u0631\u0648\u0627\u0646\u067e\u0632\u0634\u06a9\u06cc \u062f\u0627\u0631\u06cc\u062f\u061f\u0622\u06cc\u0627 \u062f\u0631 6 \u0645\u0627\u0647 \u0627\u062e\u06cc\u0631 \u062c\u0631\u0627\u062d\u06cc \u06cc\u0627 \u0648\u0627\u06a9\u0633\u0646 \u062f\u0627\u0634\u062a\u0647\u200c\u0627\u06cc\u062f\u061f\n\u062c : \u0627\u0632 \u0632\u0645\u0627\u0646 \u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0647 \u0622\u0633\u0645 \u060c \u0645\u0631\u062a\u0628 \u0627\u0633\u067e\u0631\u06cc \u0633\u0627\u0644\u0628\u0648\u062a\u0627\u0645\u0648\u0644 \u0648 \u06af\u0627\u0647\u0627 \u0627\u0633\u067e\u0631\u06cc \u0647\u0627\u06cc \u062f\u06cc\u06af\u0631\u06cc \u0645\u0627\u0646\u0646\u062f \u0628\u06a9\u0644\u0648\u0645\u062a\u0627\u0632\u0648\u0646 \u0648\u063a\u06cc\u0631\u0647 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc \u06a9\u0646\u0645.\n\u062f\u0631 \u0634\u062f\u062a \u0622\u0633\u0645 \u060c \u067e\u0631\u062f\u0646\u06cc\u0632\u0648\u0644\u0648\u0646 \u0647\u0645 \u0628\u0631\u0627\u06cc \u06cc\u06a9 \u0647\u0641\u062a\u0647 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc \u06a9\u0646\u0645 \u0648 \u0628\u0639\u062f \u0627\u0632 \u0628\u0647\u0628\u0648\u062f\u06cc\u00a0 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u0622\u0646 \u0631\u0627\u00a0 \u0642\u0637\u0639 \u0645\u06cc \u06a9\u0646\u0645 \u0628\u0647 \u062f\u0633\u062a\u0648\u0631 \u067e\u0632\u0634\u06a9.\n\u062f\u0631 \u06f6 \u0645\u0627\u0647 \u0627\u062e\u06cc\u0631 \u0648\u0627\u06a9\u0633\u0646 \u0648 \u062c\u0631\u0627\u062d\u06cc \u0646\u062f\u0627\u0634\u062a\u0647 \u0627\u0645 .\n\n13. \u06cc\u0627\u062f\u062f\u0627\u0634\u062a \u0622\u0632\u0627\u062f\u0622\u06cc\u0627 \u0686\u06cc\u0632 \u062f\u06cc\u06af\u0631\u06cc \u0647\u0633\u062a \u06a9\u0647 \u0641\u06a9\u0631 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u062f \u0628\u0631\u0627\u06cc \u062f\u0631\u06a9 \u0628\u0647\u062a\u0631 \u0645\u0634\u06a9\u0644 \u0634\u0645\u0627 \u0645\u0647\u0645 \u0627\u0633\u062a\u061f\n\u062c:\u00a0 \u062f\u0631 \u062d\u0627\u0644\u062a \u062e\u0648\u0634\u06cc \u060c \u0647\u0648\u0627\u06cc \u067e\u0627\u06a9 \u060c \u062c\u0645\u0639 \u062f\u0648\u0633\u062a\u0627\u0646 \u0648 \u062e\u0627\u0646\u0648\u0627\u062f\u0647 \u060c \u0633\u0641\u0631 \u0648 \u062a\u0641\u0631\u06cc\u062d \u060c \u0641\u0635\u0644 \u06af\u0631\u0645\u0627 \u062d\u0627\u0644\u0645 \u0628\u0647\u062a\u0631 \u0645\u06cc \u0634\u0648\u062f .", "top_remedies": ["ars", "kali-s", "kali-c"], "timestamp": "2026-04-25T08:39:46.224161"}
