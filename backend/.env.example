# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
REDIS_URL=redis://host:6379

# Security
JWT_SECRET=<min-32-char-random-string>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin
ADMIN_API_KEY=<secret-key>
ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8

# Storage
LIARA_ACCESS_KEY=<access-key>
LIARA_SECRET_KEY=<secret-key>
LIARA_BUCKET_NAME=diabetic-shop
LIARA_ENDPOINT_URL=https://storage.liara.ir

# SMS
KAVENEGAR_API_KEY=<api-key>
KAVENEGAR_SENDER=3000505

# App
ENVIRONMENT=production
APP_URL=https://diabetic-mashhad.ir
API_URL=https://api.diabetic-mashhad.ir

# CORS
CORS_ORIGINS=["https://diabetic-mashhad.ir"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
OTP_RATE_LIMIT_PER_MINUTE=10

# OTP
OTP_TTL_SECONDS=90
OTP_MAX_TRIES=3

# Cleanup Job
RESERVATION_TIMEOUT_HOURS=24
CLEANUP_JOB_INTERVAL_HOURS=1
CLEANUP_JOB_LOCK_TTL_SECONDS=300
